<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SecretChat.Mobile.Pages.Base.BasePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:SecretChat.Mobile.Controls"
    xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
    ios:Page.PrefersHomeIndicatorAutoHidden="True"
    Shell.NavBarIsVisible="False">

    <Grid SafeAreaEdges="None">

        <Grid
            x:Name="PageContentGrid"
            IsVisible="{Binding IsShowContent}"
            SafeAreaEdges="None" />

        <controls:LoadingIndicator
            HorizontalOptions="Center"
            IsBusy="{Binding IsBusy}"
            LoadingText="{Binding LoadingText}"
            VerticalOptions="Center" />

        <controls:ErrorIndicator
            ErrorImage="{Binding ErrorImage}"
            ErrorText="{Binding ErrorText}"
            HorizontalOptions="Center"
            IsError="{Binding IsErrorState}"
            VerticalOptions="Center" />

    </Grid>

</ContentPage>