<?xml version="1.0" encoding="utf-8" ?>
<Grid
    x:Class="SecretChat.Mobile.Controls.TopPanel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:contols="clr-namespace:SecretChat.Mobile.Controls"
    xmlns:icons="clr-namespace:SecretChat.Mobile.Common.MaterialIcons"
    Padding="10"
    ColumnDefinitions="Auto, Auto, *, Auto"
    ColumnSpacing="10">

    <Label
        x:Name="LeftTextLabel"
        Grid.Column="0"
        HorizontalOptions="Center"
        Style="{StaticResource MaterialIcon}"
        VerticalOptions="Center" />

    <contols:SmallUserImage
        x:Name="UserImageControl"
        Grid.Column="1"
        IsVisible="False" />

    <Label
        x:Name="MiddleTextLabel"
        Grid.Column="2"
        FontAttributes="Bold"
        FontSize="24"
        HorizontalOptions="Start"
        TextColor="{StaticResource Primary}"
        VerticalOptions="Center" />

    <Label
        x:Name="RightTextLabel"
        Grid.Column="3"
        HorizontalOptions="Center"
        Style="{StaticResource MaterialIcon}"
        VerticalOptions="Center" />

</Grid>
