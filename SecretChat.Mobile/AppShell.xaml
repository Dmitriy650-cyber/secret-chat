<?xml version="1.0" encoding="UTF-8" ?>
<simpleShell:SimpleShell
    x:Class="SecretChat.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:SecretChat.Mobile.Controls"
    xmlns:local="clr-namespace:SecretChat.Mobile"
    xmlns:pages="clr-namespace:SecretChat.Mobile.Pages"
    xmlns:simpleShell="clr-namespace:SimpleToolkit.SimpleShell;assembly=SimpleToolkit.SimpleShell"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <TabBar x:Name="tabBar" />

    <simpleShell:SimpleShell.RootPageContainer>
        <Grid SafeAreaEdges="None">

            <simpleShell:SimpleNavigationHost x:Name="pageContainer" />

            <controls:FloatingBottomBarView
                x:Name="floatingBottomBar"
                CurrentPageSelectionChanged="floatingBottomBar_CurrentPageSelectionChanged"
                HorizontalOptions="Fill"
                VerticalOptions="End" />

        </Grid>
    </simpleShell:SimpleShell.RootPageContainer>

</simpleShell:SimpleShell>
